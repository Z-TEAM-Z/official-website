---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
  tags: string[];
  tagProps?: HTMLAttributes<'a'>;
  renderLabel?: (tag: string) => string;
}

const { tags, tagProps = {}, renderLabel, class: className, ...attrs } = Astro.props;
const { class: tagClassName, ...tagAttrs } = tagProps;
---

{
  tags.length > 0 && (
    <div class:list={['tag-list', className]} {...attrs}>
      {tags.map((tag) => (
        <a class:list={['tag', tagClassName]} href={`/docs/tags/${tag}`} {...tagAttrs}>
          {renderLabel ? renderLabel(tag) : tag}
        </a>
      ))}
    </div>
  )
}

<style>
  :where(.tag-list) {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  :where(.tag) {
    display: inline-block;
    padding: 2px 10px;
    background: #eee;
    border-radius: 4px;
    font-size: 0.85em;
    text-decoration: none;
    color: #333;
  }

  :where(.tag):hover {
    background: #ddd;
  }
</style>
