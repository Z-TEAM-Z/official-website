---
import AlpineProvider from '@/components/alpine/alpine-provider/index.astro';
---

<AlpineProvider>
  <div class="counter" x-data="{ count: 0 }">
    <button type="button" x-on:click="count--">-</button>
    <span x-text="count">0</span>
    <button type="button" x-on:click="count++">+</button>
  </div>
</AlpineProvider>
