---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import { getCollection, render } from 'astro:content';
import TagList from '@/components/astro/tag-list/index.astro';
import Layout from '@/layouts/base-layout.astro';
import { withBase } from '@/utils/url';

export const getStaticPaths = (async () => {
  const docs = await getCollection('docs');
  return docs.map((doc) => ({
    params: { id: doc.id },
    props: { doc },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { doc } = Astro.props as Props;
const { Content } = await render(doc);
---

<Layout title={doc.data.title}>
  <article>
    <header>
      <h2>{doc.data.title}</h2>
      <p>
        <small>
          作者: {doc.data.author} | 发布: {doc.data.pubDate.toLocaleDateString('zh-CN')}
        </small>
      </p>
      {doc.data.tags && <TagList tags={doc.data.tags} />}
      {
        doc.data.image?.url && (
          <img src={doc.data.image.url} alt={doc.data.image.alt} style="max-width: 100%; border-radius: 8px;" />
        )
      }
    </header>
    <hr />
    <Content />
    <hr />
    <a href={withBase('/docs')}>← 返回文档列表</a>
  </article>
</Layout>
