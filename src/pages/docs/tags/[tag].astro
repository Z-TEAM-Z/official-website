---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import { getCollection } from 'astro:content';
import TagList from '@/components/astro/tag-list/index.astro';
import Layout from '@/layouts/base-layout.astro';
import { withBase } from '@/utils/url';

export const getStaticPaths = (async () => {
  const docs = await getCollection('docs');
  const tagSet = new Set<string>();

  for (const doc of docs) {
    for (const tag of doc.data.tags ?? []) {
      tagSet.add(tag);
    }
  }

  return [...tagSet].map((tag) => ({
    params: { tag },
    props: {
      tag,
      docs: docs.filter((doc) => doc.data.tags?.includes(tag)),
    },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { tag, docs } = Astro.props as Props;
---

<Layout title={`标签: ${tag}`}>
  <section>
    <h2>🏷️ 标签: {tag}</h2>
    <p>共 {docs.length} 篇文档</p>
    <ul>
      {
        docs.map((doc) => (
          <li>
            <a href={withBase(`/docs/${doc.id}`)}>
              <strong>{doc.data.title}</strong>
            </a>
            <span> — {doc.data.description}</span>
            <br />
            <small>
              作者: {doc.data.author} | 发布: {doc.data.pubDate.toLocaleDateString('zh-CN')}
            </small>
            {doc.data.tags && <TagList tags={doc.data.tags} />}
          </li>
        ))
      }
    </ul>
    <hr />
    <a href={withBase('/docs/tags')}>← 返回标签列表</a>
  </section>
</Layout>
