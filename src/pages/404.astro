---
import BaseLayout from '@/layouts/base-layout.astro';
---

<BaseLayout title="404 - 页面未找到">
  <div class="not-found">
    <h1>404</h1>
    <p>抱歉，你访问的页面不存在。</p>
    <a href="/">返回首页</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
  }

  h1 {
    font-size: 6rem;
    margin: 0;
    color: #666;
  }

  p {
    font-size: 1.25rem;
    color: #888;
    margin: 1rem 0 2rem;
  }

  a {
    padding: 0.5rem 1.5rem;
    background: #333;
    color: #fff;
    text-decoration: none;
    border-radius: 4px;
  }

  a:hover {
    background: #555;
  }
</style>
